      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 04 — Collaborative filtering / SVD (System 2)\n",
        "\n",
        "**Phase 2.3** — Matrix factorisation with scikit-surprise SVD.\n",
        "\n",
        Trains on 80% of interactions, reports RMSE on held-out 20%."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "from pathlib import Path\n",
        "import sys\n",
        "\n",
        "ROOT = Path.cwd().parent if Path.cwd().name == \"notebooks\" else Path.cwd()\n",
        "sys.path.insert(0, str(ROOT))\n",
        "\n",
        "from src.data_loader import load_fridgewise_data\n",
        "from src.models.collaborative import CollaborativeRecommender"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "data = load_fridgewise_data(ROOT)\n",
        "model = CollaborativeRecommender(n_factors=50, n_epochs=20).fit(data, test_size=0.2)\n",
        "model.save(ROOT / \"src\" / \"models\" / \"artifacts\" / \"svd.pkl\")\n",
        "print(f\"SVD test RMSE: {model.rmse:.4f}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import pandas as pd\n",
        "\n",
        "user_id = int(data.interactions[\"user_id\"].value_counts().index[0])\n",
        "n_ratings = len(data.interactions[data.interactions[\"user_id\"] == user_id])\n",
        "print(f\"User {user_id} has {n_ratings} ratings in training data\")\n",
        "\n",
        "recs = model.recommend(user_id, k=10)\n",
        "pd.DataFrame([{\"rank\": i+1, \"recipe_id\": r.recipe_id, \"recipe_name\": r.recipe_name, \"predicted_rating\": round(r.score, 3)}\n",
        "              for i, r in enumerate(recs)])"
      ],
      "execution_count": null,
      "outputs": []
    }
  ]
}
