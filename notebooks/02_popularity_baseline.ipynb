      "source": [
        "# 02 — Popularity baseline\n",
        "\n",
        "**Phase 2.1** — Global recipe ranking by Bayesian-smoothed popularity (interaction count × mean rating).\n",
        "\n",
        **Prerequisites:** Phase 1 complete (`data/clean/clean_interactions.csv`)."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "from pathlib import Path\n",
        "import sys\n",
        "\n",
        "ROOT = Path.cwd().parent if Path.cwd().name == \"notebooks\" else Path.cwd()\n",
        "sys.path.insert(0, str(ROOT))\n",
        "\n",
        "from src.data_loader import load_fridgewise_data\n",
        "from src.models.popularity import PopularityRecommender"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "data = load_fridgewise_data(ROOT)\n",
        "model = PopularityRecommender().fit(data)\n",
        "model.save(ROOT / \"src\" / \"models\" / \"artifacts\" / \"popularity.pkl\")\n",
        "print(f\"Ranked {len(model.recipe_scores)} recipes\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import pandas as pd\n",
        "\n",
        "user_id = int(data.interactions[\"user_id\"].value_counts().index[0])\n",
        "recs = model.recommend(user_id, k=10)\n",
        "\n",
        "pd.DataFrame([{\"rank\": i+1, \"recipe_id\": r.recipe_id, \"recipe_name\": r.recipe_name, \"score\": round(r.score, 3)}\n",
        "              for i, r in enumerate(recs)])"
      ],
      "execution_count": null,
      "outputs": []
    }
  ]
}
