      "source": [
        "# 03 — Content-based recommender (System 1)\n",
        "\n",
        "**Phase 2.2** — TF-IDF on recipe ingredients/tags + fridge ingredient match score.\n",
        "\n",
        Uses synthetic fridge inventory from Phase 1 for demo users."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "from pathlib import Path\n",
        "import sys\n",
        "\n",
        "ROOT = Path.cwd().parent if Path.cwd().name == \"notebooks\" else Path.cwd()\n",
        "sys.path.insert(0, str(ROOT))\n",
        "\n",
        "from src.data_loader import load_fridgewise_data\n",
        "from src.models.content_based import ContentBasedRecommender"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "data = load_fridgewise_data(ROOT)\n",
        "model = ContentBasedRecommender(match_weight=0.6).fit(data)\n",
        "model.save(ROOT / \"src\" / \"models\" / \"artifacts\" / \"content_based.pkl\")\n",
        "print(f\"TF-IDF vocabulary: {len(model.vectorizer.vocabulary_)}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import pandas as pd\n",
        "\n",
        "demo_user = int(data.profiles.iloc[0][\"user_id\"])\n",
        "fridge_items = data.fridge[data.fridge[\"user_id\"] == demo_user][\"cleaned_ingredient_name\"].tolist()\n",
        "print(f\"User {demo_user} fridge ({len(fridge_items)} items):\", fridge_items[:8], \"...\")\n",
        "\n",
        "recs = model.recommend(demo_user, k=10)\n",
        "pd.DataFrame([{\"rank\": i+1, \"recipe_id\": r.recipe_id, \"recipe_name\": r.recipe_name, \"score\": round(r.score, 3)}\n",
        "              for i, r in enumerate(recs)])"
      ],
      "execution_count": null,
      "outputs": []
    }
  ]
}
