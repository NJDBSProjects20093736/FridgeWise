# FridgeWise — copy to .env and fill in (never commit .env)

# Supabase project
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

# From Supabase Dashboard → Settings → API
SUPABASE_ANON_KEY=eyJ...anon...          # safe for Flutter / browser (with RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJ...         # backend ONLY — never in Flutter or git

# Aliases (optional)
SUPABASE_PUBLISHABLE_KEY=${SUPABASE_ANON_KEY}
SUPABASE_SECRET_KEY=${SUPABASE_SERVICE_ROLE_KEY}

# Direct Postgres (Supabase Dashboard → Settings → Database → Connection string)
# Use "Session pooler" for FastAPI / server apps
# Password must be percent-encoded in URL (& -> %26, @ -> %40, etc.)
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_ENCODED_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

DEMO_LEGACY_USER_ID=5060

# API
API_HOST=0.0.0.0
API_PORT=8000
